# =============================================================================
# Chronicle AI TRPG — 환경변수 설정
# =============================================================================
# 1. 이 파일을 복사해서 .env 를 만드세요:   cp .env.example .env  (또는 start.bat 실행)
# 2. 아래 값들을 채워주세요.
# 3. .env 파일은 절대 git에 올리지 마세요 (.gitignore에 이미 포함됨)
# =============================================================================

# ── PostgreSQL 데이터베이스 ──────────────────────────────────────────────────
#
# [무료] Neon (클라우드 PostgreSQL, 가입 즉시 사용 가능):
#   https://neon.tech → New Project → Connection string 복사
#   형식: postgresql://유저:비밀번호@호스트/데이터베이스?sslmode=require
#
# [로컬] PostgreSQL을 직접 설치한 경우:
#   postgresql://postgres:비밀번호@localhost:5432/chronicle
#
DATABASE_URL=postgresql://user:password@localhost:5432/chronicle

# ── OpenAI API 키 ────────────────────────────────────────────────────────────
#
# https://platform.openai.com/api-keys 에서 발급
# gpt-4o 모델을 사용합니다 (유료, 사용량 기반 과금)
#
OPENAI_API_KEY=sk-...

# ── 포트 설정 (선택사항 — 기본값으로 그냥 두세요) ────────────────────────────
# API 서버 포트 (기본: 10000)
# PORT=10000
#
# Vite 웹 서버 포트 (기본: 3000)
# 웹 서버의 /api 요청은 자동으로 API_PORT로 프록시됩니다
# API_PORT=10000
