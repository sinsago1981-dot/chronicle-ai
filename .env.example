# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by both the API server and drizzle migrations.
# Never commit .env to git.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local PostgreSQL example: postgresql://postgres:password@localhost:5432/chronicle
DATABASE_URL=postgresql://user:password@localhost:5432/chronicle

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Server ports (optional — sensible defaults are already set) ──────────────
# API server listens on PORT (default: 10000)
# PORT=10000
#
# Vite dev server listens on PORT too (default: 3000).
# The Vite proxy forwards /api requests to API_PORT (default: 10000).
# Override API_PORT only if you changed the API server port above.
# API_PORT=10000
